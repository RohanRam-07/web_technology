<!-- BOOKING FORM -->
<h2 id="booking">Room Booking Form</h2>
<p>Please fill in all details below to complete your reservation.</p>

<form action="booking_confirm.html" method="post">

  <h3>1. Select Room</h3>
  <table border="1" cellpadding="8">
    <tr>
      <td><label for="room">Room Type:</label></td>
      <td>
        <select name="room" id="room" required>
          <option value="">-- Select a Room --</option>
          <option value="classic">Classic King Room — $220/night</option>
          <option value="deluxe">Deluxe Sea View — $320/night</option>
          <option value="junior">Junior Suite — $480/night</option>
          <option value="penthouse">Grand Penthouse — $1,200/night</option>
          <option value="villa">Garden Villa — $850/night</option>
          <option value="studio">Urban Studio — $180/night</option>
        </select>
      </td>
    </tr>
    <tr>
      <td><label for="checkin2">Check-In Date:</label></td>
      <td><input type="date" name="checkin" id="checkin2" required /></td>
    </tr>
    <tr>
      <td><label for="checkout2">Check-Out Date:</label></td>
      <td><input type="date" name="checkout" id="checkout2" required /></td>
    </tr>
    <tr>
      <td><label for="nights">Number of Nights:</label></td>
      <td><input type="number" name="nights" id="nights" min="1" max="30" value="1" required /></td>
    </tr>
    <tr>
      <td><label for="rooms_count">Number of Rooms:</label></td>
      <td>
        <select name="rooms_count" id="rooms_count">
          <option>1</option>
          <option>2</option>
          <option>3</option>
        </select>
      </td>
    </tr>
    <tr>
      <td><label for="guests2">Number of Guests:</label></td>
      <td>
        <select name="guests" id="guests2">
          <option>1 Guest</option>
          <option>2 Guests</option>
          <option>3 Guests</option>
          <option>4 Guests</option>
          <option>5+ Guests</option>
        </select>
      </td>
    </tr>
  </table>

  <br />

  <h3>2. Guest Information</h3>
  <table border="1" cellpadding="8">
    <tr>
      <td><label for="fname">First Name:</label></td>
      <td><input type="text" name="fname" id="fname" placeholder="Enter first name" required /></td>
      <td><label for="lname">Last Name:</label></td>
      <td><input type="text" name="lname" id="lname" placeholder="Enter last name" required /></td>
    </tr>
    <tr>
      <td><label for="email">Email Address:</label></td>
      <td><input type="email" name="email" id="email" placeholder="you@email.com" required /></td>
      <td><label for="phone">Phone Number:</label></td>
      <td><input type="tel" name="phone" id="phone" placeholder="+1 555 000 0000" required /></td>
    </tr>
    <tr>
      <td><label for="dob">Date of Birth:</label></td>
      <td><input type="date" name="dob" id="dob" /></td>
      <td><label for="nationality">Nationality:</label></td>
      <td>
        <select name="nationality" id="nationality">
          <option>Indian</option>
          <option>American</option>
          <option>British</option>
          <option>French</option>
          <option>Japanese</option>
          <option>Australian</option>
          <option>Canadian</option>
          <option>Other</option>
        </select>
      </td>
    </tr>
    <tr>
      <td><label for="id_type">ID Type:</label></td>
      <td>
        <select name="id_type" id="id_type">
          <option>Passport</option>
          <option>Driver's Licence</option>
          <option>National ID</option>
          <option>Aadhar Card</option>
        </select>
      </td>
      <td><label for="id_number">ID Number:</label></td>
      <td><input type="text" name="id_number" id="id_number" placeholder="Enter ID number" required /></td>
    </tr>
    <tr>
      <td><label for="address">Home Address:</label></td>
      <td colspan="3"><textarea name="address" id="address" rows="3" cols="50" placeholder="Enter your full address"></textarea></td>
    </tr>
  </table>

  <br />

  <h3>3. Special Requests</h3>
  <table border="1" cellpadding="8">
    <tr>
      <td>Bed Preference:</td>
      <td>
        <input type="radio" name="bed" value="king" /> King Bed &nbsp;
        <input type="radio" name="bed" value="twin" /> Twin Beds &nbsp;
        <input type="radio" name="bed" value="any" checked /> No Preference
      </td>
    </tr>
    <tr>
      <td>Floor Preference:</td>
      <td>
        <input type="radio" name="floor" value="high" /> High Floor &nbsp;
        <input type="radio" name="floor" value="low" /> Low Floor &nbsp;
        <input type="radio" name="floor" value="any" checked /> No Preference
      </td>
    </tr>
    <tr>
      <td>Add-ons:</td>
      <td>
        <input type="checkbox" name="addon" value="airport" /> Airport Transfer (+$50) &nbsp;
        <input type="checkbox" name="addon" value="breakfast" /> Extra Breakfast (+$30) &nbsp;
        <input type="checkbox" name="addon" value="spa" /> Spa Package (+$120) <br />
        <input type="checkbox" name="addon" value="flowers" /> Welcome Flowers (+$40) &nbsp;
        <input type="checkbox" name="addon" value="late_checkout" /> Late Checkout (+$60)
      </td>
    </tr>
    <tr>
      <td>Dietary Needs:</td>
      <td>
        <select name="dietary">
          <option>None</option>
          <option>Vegetarian</option>
          <option>Vegan</option>
          <option>Halal</option>
          <option>Gluten-Free</option>
          <option>Kosher</option>
        </select>
      </td>
    </tr>
    <tr>
      <td>Other Requests:</td>
      <td><textarea name="requests" rows="3" cols="50" placeholder="e.g. early check-in, baby cot, accessibility needs..."></textarea></td>
    </tr>
  </table>

  <br />

  <h3>4. Payment Details</h3>
  <table border="1" cellpadding="8">
    <tr>
      <td>Payment Method:</td>
      <td>
        <input type="radio" name="payment" value="card" checked /> Credit / Debit Card &nbsp;
        <input type="radio" name="payment" value="upi" /> UPI &nbsp;
        <input type="radio" name="payment" value="netbanking" /> Net Banking &nbsp;
        <input type="radio" name="payment" value="paypal" /> PayPal
      </td>
    </tr>
    <tr>
      <td><label for="cardname">Name on Card:</label></td>
      <td><input type="text" name="cardname" id="cardname" placeholder="As printed on card" required /></td>
    </tr>
    <tr>
      <td><label for="cardnum">Card Number:</label></td>
      <td><input type="text" name="cardnum" id="cardnum" placeholder="1234 5678 9012 3456" maxlength="19" required /></td>
    </tr>
    <tr>
      <td><label for="expiry">Expiry Date:</label></td>
      <td><input type="text" name="expiry" id="expiry" placeholder="MM/YY" maxlength="5" required /></td>
    </tr>
    <tr>
      <td><label for="cvv">CVV:</label></td>
      <td><input type="password" name="cvv" id="cvv" placeholder="•••" maxlength="4" size="5" required /></td>
    </tr>
  </table>

  <br />

  <h3>5. Booking Summary</h3>
  <table border="1" cellpadding="8" bgcolor="#fffbf0">
    <tr>
      <td><b>Room Rate:</b></td>
      <td>As selected above (per night)</td>
    </tr>
    <tr>
      <td><b>Taxes &amp; Fees:</b></td>
      <td>12% of total room cost</td>
    </tr>
    <tr>
      <td><b>Cancellation Policy:</b></td>
      <td>Free cancellation up to 48 hours before check-in</td>
    </tr>
    <tr>
      <td><b>Check-In Time:</b></td>
      <td>2:00 PM onwards</td>
    </tr>
    <tr>
      <td><b>Check-Out Time:</b></td>
      <td>12:00 PM (Noon)</td>
    </tr>
    <tr>
      <td><b>Confirmation:</b></td>
      <td>Sent to your email within 10 minutes</td>
    </tr>
  </table>

  <br />

  <p>
    <input type="checkbox" name="terms" required />
    I agree to the <a href="#terms">Terms &amp; Conditions</a> and <a href="#privacy">Privacy Policy</a> of Rajalakshmi Hotels.
  </p>

  <p>
    <input type="checkbox" name="newsletter" />
    Subscribe to Rajalakshmi Hotels newsletter for exclusive offers.
  </p>

  <br />
  <input type="submit" value="Confirm Booking" />
  &nbsp;&nbsp;
  <input type="reset" value="Clear Form" />

</form>

