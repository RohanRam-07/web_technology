                <label><input type="radio" name="bed" value="twin" /> Twin Beds</label>
                <label><input type="radio" name="bed" value="any" checked /> No Preference</label>
              </div>
            </div>
            <div class="form-group full">
              <label>Floor Preference</label>
              <div class="radio-group">
                <label><input type="radio" name="floor" value="high" /> High Floor</label>
                <label><input type="radio" name="floor" value="low" /> Low Floor</label>
                <label><input type="radio" name="floor" value="any" checked /> No Preference</label>
              </div>
            </div>
            <div class="form-group full">
              <label>Add-On Services</label>
              <div class="check-group">
                <label><input type="checkbox" name="addon" value="airport" /> Airport Transfer (+₹3,000)</label>
                <label><input type="checkbox" name="addon" value="breakfast" /> Extra Breakfast (+₹800)</label>
                <label><input type="checkbox" name="addon" value="spa" /> Spa Package (+₹5,000)</label>
                <label><input type="checkbox" name="addon" value="flowers" /> Welcome Flowers (+₹1,500)</label>
                <label><input type="checkbox" name="addon" value="late" /> Late Checkout (+₹2,500)</label>
