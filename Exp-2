<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Rajalakshmi Hotels & Resorts</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
  <style>

    /* ── RESET & ROOT ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --maroon:     #7b1c2e;
      --maroon-dk:  #4e0f1c;
      --maroon-lt:  #a63248;
      --gold:       #c9973a;
      --gold-lt:    #e8c97a;
      --gold-pale:  #f5ead0;
      --cream:      #fdf8f0;
      --white:      #ffffff;
      --text:       #2e1a1a;
      --muted:      #7a5c5c;
      --border:     #e2cdb5;
      --shadow:     rgba(123,28,46,0.12);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Lato', sans-serif;
      background: var(--cream);
      color: var(--text);
      line-height: 1.6;
    }

    /* ── NAVBAR ── */
    nav {
      background: var(--maroon-dk);
      padding: 0 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 3px solid var(--gold);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .nav-logo {
      padding: 1rem 0;
    }

    .nav-logo h1 {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--gold-lt);
      letter-spacing: 0.05em;
    }

    .nav-logo span {
      font-size: 0.65rem;
      color: var(--gold);
      letter-spacing: 0.25em;
      text-transform: uppercase;
      display: block;
    }

    .nav-links {
      list-style: none;
      display: flex;
      gap: 0;
    }

    .nav-links li a {
      display: block;
      padding: 1.4rem 1.4rem;
      color: #e8d5c0;
      text-decoration: none;
      font-size: 0.78rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      font-weight: 700;
      border-bottom: 3px solid transparent;
      margin-bottom: -3px;
      transition: color 0.3s, border-color 0.3s;
    }

    .nav-links li a:hover {
      color: var(--gold-lt);
      border-bottom-color: var(--gold);
    }

    /* ── HERO ── */
    .hero {
      background: linear-gradient(135deg, var(--maroon-dk) 0%, var(--maroon) 50%, #5c1525 100%);
      padding: 6rem 3rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 50% at 50% 50%, rgba(201,151,58,0.15) 0%, transparent 70%);
    }

    .hero-badge {
      display: inline-block;
      border: 1px solid var(--gold);
      color: var(--gold);
      font-size: 0.65rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      padding: 0.4rem 1.5rem;
      margin-bottom: 1.5rem;
    }

    .hero h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.5rem, 6vw, 4.5rem);
      font-weight: 400;
      color: var(--gold-lt);
      line-height: 1.15;
      margin-bottom: 1rem;
      position: relative;
    }

    .hero h2 em {
      font-style: italic;
      color: var(--gold);
    }

    .hero p {
      color: #d4b89a;
      font-size: 1rem;
      font-weight: 300;
      max-width: 520px;
      margin: 0 auto 2.5rem;
    }

    .hero-stats {
      display: flex;
      justify-content: center;
      gap: 4rem;
      position: relative;
    }

    .hero-stat {
      text-align: center;
    }

    .hero-stat strong {
      display: block;
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      color: var(--gold-lt);
      line-height: 1;
    }

    .hero-stat span {
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #c4a07a;
    }

    /* ── SECTION COMMON ── */
    section {
      padding: 5rem 3rem;
    }

    .section-label {
      font-size: 0.65rem;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 0.5rem;
      display: block;
    }

    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      font-weight: 400;
      color: var(--maroon-dk);
      margin-bottom: 0.5rem;
    }

    .section-title em {
      font-style: italic;
      color: var(--maroon-lt);
    }

    .section-sub {
      color: var(--muted);
      font-size: 0.9rem;
      margin-bottom: 3rem;
      max-width: 550px;
    }

    .divider {
      width: 60px;
      height: 2px;
      background: linear-gradient(to right, var(--gold), transparent);
      margin: 1rem 0 2.5rem;
    }

    /* ── SEARCH BAR ── */
    .search-section {
      background: var(--maroon);
      padding: 2.5rem 3rem;
      border-top: 1px solid var(--maroon-lt);
      border-bottom: 4px solid var(--gold);
    }

    .search-section h3 {
      font-family: 'Playfair Display', serif;
      color: var(--gold-lt);
      font-size: 1.2rem;
      font-weight: 400;
      margin-bottom: 1.2rem;
    }

    .search-form {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: flex-end;
    }

    .search-field {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      flex: 1;
      min-width: 150px;
    }

    .search-field label {
      font-size: 0.62rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      font-weight: 700;
    }

    .search-field input,
    .search-field select {
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(201,151,58,0.4);
      color: #f0dfc0;
      padding: 0.7rem 1rem;
      font-family: 'Lato', sans-serif;
      font-size: 0.88rem;
      outline: none;
      transition: border-color 0.3s, background 0.3s;
    }

    .search-field input:focus,
    .search-field select:focus {
      border-color: var(--gold);
      background: rgba(255,255,255,0.15);
    }

    .search-field select option { background: var(--maroon-dk); color: #f0dfc0; }

    .search-btn {
      background: var(--gold);
      color: var(--maroon-dk);
      border: none;
      padding: 0.75rem 2.5rem;
      font-family: 'Lato', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.3s;
      align-self: flex-end;
    }

    .search-btn:hover { background: var(--gold-lt); }

    /* ── ABOUT ── */
    .about-section {
      background: var(--white);
      padding: 5rem 3rem;
    }

    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      max-width: 1100px;
      margin: 0 auto;
      align-items: start;
    }

    .about-info-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1.5rem;
    }

    .about-info-table tr {
      border-bottom: 1px solid var(--border);
    }

    .about-info-table td {
      padding: 0.75rem 0.5rem;
      font-size: 0.88rem;
    }

    .about-info-table td:first-child {
      font-weight: 700;
      color: var(--maroon);
      width: 130px;
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .about-info-table td:last-child { color: var(--muted); }

    .about-highlights {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-top: 1.5rem;
    }

    .highlight-card {
      background: var(--gold-pale);
      border-left: 3px solid var(--gold);
      padding: 1.2rem;
    }

    .highlight-card .icon { font-size: 1.5rem; margin-bottom: 0.4rem; }

    .highlight-card h4 {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      color: var(--maroon-dk);
      margin-bottom: 0.2rem;
    }

    .highlight-card p { font-size: 0.78rem; color: var(--muted); }

    /* ── ROOMS ── */
    .rooms-section { background: var(--cream); }

    .rooms-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1.8rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .room-card {
      background: var(--white);
      border: 1px solid var(--border);
      overflow: hidden;
      transition: transform 0.3s, box-shadow 0.3s;
    }

    .room-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 16px 40px var(--shadow);
    }

    .room-banner {
      height: 170px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      font-size: 3.5rem;
    }

    .room-banner.classic  { background: linear-gradient(135deg, #8b6246 0%, #c4956a 100%); }
    .room-banner.deluxe   { background: linear-gradient(135deg, #1e5546 0%, #3a8a6e 100%); }
    .room-banner.suite    { background: linear-gradient(135deg, #4e0f1c 0%, #7b1c2e 100%); }
    .room-banner.pent     { background: linear-gradient(135deg, #1a1a3a 0%, #2e2e6a 100%); }
    .room-banner.villa    { background: linear-gradient(135deg, #1e3a20 0%, #3a6e3e 100%); }
    .room-banner.studio   { background: linear-gradient(135deg, #3a2a1e 0%, #6e4e32 100%); }

    .room-tag {
      position: absolute;
      top: 0.8rem;
      left: 0.8rem;
      background: var(--gold);
      color: var(--maroon-dk);
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 0.25rem 0.7rem;
    }

    .avail-dot {
      position: absolute;
      top: 0.8rem;
      right: 0.8rem;
      font-size: 0.65rem;
      font-weight: 700;
      padding: 0.25rem 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .avail-dot.green  { background: #d4edda; color: #155724; }
    .avail-dot.orange { background: #fff3cd; color: #856404; }
    .avail-dot.red    { background: #f8d7da; color: #721c24; }

    .room-body { padding: 1.4rem; }

    .room-type-label {
      font-size: 0.62rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      font-weight: 700;
      margin-bottom: 0.3rem;
    }

    .room-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.25rem;
      color: var(--maroon-dk);
      margin-bottom: 0.4rem;
    }

    .room-desc {
      font-size: 0.82rem;
      color: var(--muted);
      margin-bottom: 0.9rem;
      line-height: 1.5;
    }

    .room-amenities {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      margin-bottom: 1rem;
    }

    .amenity {
      font-size: 0.65rem;
      border: 1px solid var(--border);
      color: var(--muted);
      padding: 0.2rem 0.55rem;
      background: var(--gold-pale);
      letter-spacing: 0.04em;
    }

    .room-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
    }

    .room-price strong {
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem;
      color: var(--maroon-dk);
      display: block;
      line-height: 1;
    }

    .room-price small {
      font-size: 0.68rem;
      color: var(--muted);
    }

    .room-rating {
      font-size: 0.78rem;
      color: var(--gold);
      font-weight: 700;
    }

    .book-link {
      display: inline-block;
      background: var(--maroon);
      color: var(--gold-lt);
      text-decoration: none;
      padding: 0.6rem 1.2rem;
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      font-weight: 700;
      transition: background 0.3s;
    }

    .book-link:hover { background: var(--maroon-lt); }

    .book-link.disabled {
      background: #ccc;
      color: #888;
      pointer-events: none;
      cursor: not-allowed;
    }

    /* ── BOOKING FORM ── */
    .booking-section { background: var(--white); }

    .booking-wrap {
      max-width: 860px;
      margin: 0 auto;
    }

    .form-step {
      background: var(--white);
      border: 1px solid var(--border);
      margin-bottom: 1.5rem;
      overflow: hidden;
    }

    .form-step-header {
      background: var(--maroon);
      padding: 1rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .step-num {
      background: var(--gold);
      color: var(--maroon-dk);
      width: 28px;
      height: 28px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.8rem;
      font-weight: 700;
      flex-shrink: 0;
    }

    .form-step-header h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem;
      font-weight: 400;
      color: var(--gold-lt);
    }

    .form-step-body {
      padding: 1.8rem;
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.2rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }

    .form-group.full { grid-column: 1 / -1; }

    .form-group label {
      font-size: 0.68rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--maroon);
      font-weight: 700;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      border: 1px solid var(--border);
      background: #faf6f0;
      padding: 0.75rem 1rem;
      font-family: 'Lato', sans-serif;
      font-size: 0.9rem;
      color: var(--text);
      outline: none;
      transition: border-color 0.3s, background 0.3s;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      border-color: var(--maroon);
      background: var(--white);
    }

    .form-group textarea { resize: vertical; min-height: 90px; }

    .radio-group, .check-group {
      display: flex;
      flex-wrap: wrap;
      gap: 1.2rem;
      padding: 0.5rem 0;
    }

    .radio-group label, .check-group label {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.85rem;
      color: var(--text);
      cursor: pointer;
      text-transform: none;
      letter-spacing: 0;
      font-weight: 400;
    }

    .radio-group input[type="radio"],
    .check-group input[type="checkbox"] {
      width: 16px;
      height: 16px;
      accent-color: var(--maroon);
      padding: 0;
      border: none;
    }

    /* ── SUMMARY BOX ── */
    .summary-box {
      background: var(--gold-pale);
      border: 1px solid #e2c88a;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .summary-box h4 {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      color: var(--maroon-dk);
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid #e2c88a;
    }

    .summary-row {
      display: flex;
      justify-content: space-between;
      font-size: 0.85rem;
      color: var(--muted);
      padding: 0.35rem 0;
      border-bottom: 1px dashed #e8d9b5;
    }

    .summary-row:last-child { border-bottom: none; }

    .summary-row.total {
      font-weight: 700;
      color: var(--maroon-dk);
      font-size: 1rem;
      padding-top: 0.7rem;
      border-top: 2px solid var(--gold);
      border-bottom: none;
      margin-top: 0.3rem;
    }

    /* ── FORM ACTIONS ── */
    .form-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
      flex-wrap: wrap;
      margin-top: 1rem;
    }

    .btn-primary {
      background: var(--maroon);
      color: var(--gold-lt);
      border: none;
      padding: 0.9rem 2.5rem;
      font-family: 'Lato', sans-serif;
      font-size: 0.78rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.3s;
    }

    .btn-primary:hover { background: var(--maroon-lt); }

    .btn-secondary {
      background: transparent;
      color: var(--muted);
      border: 1px solid var(--border);
      padding: 0.9rem 1.8rem;
      font-family: 'Lato', sans-serif;
      font-size: 0.78rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      cursor: pointer;
      transition: border-color 0.3s, color 0.3s;
    }

    .btn-secondary:hover { border-color: var(--maroon); color: var(--maroon); }

    .terms-check {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      font-size: 0.82rem;
      color: var(--muted);
      margin-bottom: 1rem;
    }

    .terms-check input { margin-top: 2px; accent-color: var(--maroon); }
    .terms-check a { color: var(--maroon); }

    /* ── FACILITIES ── */
    .facilities-section { background: var(--cream); }

    .facilities-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1.2rem;
      max-width: 1100px;
      margin: 0 auto;
    }

    .facility-card {
      background: var(--white);
      border: 1px solid var(--border);
      padding: 1.5rem;
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      transition: border-color 0.3s, box-shadow 0.3s;
    }

    .facility-card:hover {
      border-color: var(--gold);
      box-shadow: 0 4px 16px var(--shadow);
    }

    .facility-icon { font-size: 1.8rem; flex-shrink: 0; }

    .facility-info h4 {
      font-family: 'Playfair Display', serif;
      font-size: 0.95rem;
      color: var(--maroon-dk);
      margin-bottom: 0.2rem;
    }

    .facility-info p { font-size: 0.78rem; color: var(--muted); line-height: 1.5; }

    .facility-info .timing {
      font-size: 0.7rem;
      color: var(--gold);
      font-weight: 700;
      letter-spacing: 0.05em;
      margin-top: 0.3rem;
    }

    /* ── CONTACT ── */
    .contact-section { background: var(--white); }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1.4fr;
      gap: 4rem;
      max-width: 1000px;
      margin: 0 auto;
    }

    .contact-details table {
      width: 100%;
      border-collapse: collapse;
    }

    .contact-details table tr {
      border-bottom: 1px solid var(--border);
    }

    .contact-details table td {
      padding: 0.8rem 0.5rem;
      font-size: 0.85rem;
    }

    .contact-details table td:first-child {
      font-weight: 700;
      color: var(--maroon);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      width: 120px;
    }

    .contact-details table td:last-child { color: var(--muted); }

    /* ── TERMS ── */
    .terms-section { background: var(--cream); }

    .terms-section ol {
      max-width: 800px;
      counter-reset: terms;
      list-style: none;
      padding: 0;
    }

    .terms-section ol li {
      counter-increment: terms;
      display: flex;
      gap: 1rem;
      padding: 0.85rem 0;
      border-bottom: 1px solid var(--border);
      font-size: 0.88rem;
      color: var(--muted);
      align-items: flex-start;
    }

    .terms-section ol li::before {
      content: counter(terms, decimal-leading-zero);
      font-family: 'Playfair Display', serif;
      font-size: 0.85rem;
      color: var(--gold);
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 1px;
    }

    /* ── FOOTER ── */
    footer {
      background: var(--maroon-dk);
      border-top: 3px solid var(--gold);
      padding: 3rem;
      text-align: center;
    }

    footer .footer-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.6rem;
      color: var(--gold-lt);
      margin-bottom: 0.4rem;
    }

    footer .footer-tagline {
      font-size: 0.65rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
    }

    footer .footer-links {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.3rem;
      margin-bottom: 1.5rem;
    }

    footer .footer-links a {
      color: #c4a07a;
      text-decoration: none;
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0 1rem;
      border-right: 1px solid #5e2030;
      transition: color 0.3s;
    }

    footer .footer-links a:last-child { border-right: none; }
    footer .footer-links a:hover { color: var(--gold-lt); }

    footer p {
      font-size: 0.75rem;
      color: #8a5060;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      nav { padding: 0 1rem; flex-wrap: wrap; }
      .nav-links { display: none; }
      section { padding: 3rem 1.2rem; }
